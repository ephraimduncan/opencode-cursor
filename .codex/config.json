{
  "proxy": {
    "port": 32124,
    "host": "127.0.0.1",
    "healthUrl": "http://127.0.0.1:32124/health"
  },
  "paths": {
    "bunCommand": "bun",
    "cursorAgent": "cursor-agent",
    "opencodeCursorSrc": "src\\index.ts",
    "opencodeConfig": "%USERPROFILE%\\.config\\opencode\\opencode.json"
  },
  "auth": {
    "cursorConfigDir_darwin": "~/.cursor",
    "cursorConfigDir_linux": "~/.config/cursor",
    "authFiles": ["cli-config.json", "auth.json"]
  },
  "models": {
    "syncCommand": "cursor-agent models",
    "defaultModel": "cursor-acp/auto"
  }
}
